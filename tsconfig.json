{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@features/accounts": ["./features/accounts/api/index.ts"],
      "@features/accounts/hooks": ["./features/accounts/hooks/index.ts"],
      "@features/categories": ["./features/categories/api/index.ts"],
      "@features/categories/hooks": ["./features/categories/hooks/index.ts"],
      "@features/transactions": ["./features/transactions/api/index.ts"],
      "@features/transactions/hooks": ["./features/transactions/hooks/index.ts"],
      "@features/account-balances": ["./features/account-balances/api/index.ts"],
      "@features/account-balances/hooks": ["./features/account-balances/hooks/index.ts"],
      "@features/summary": ["./features/summary/api/index.ts"]
    },
    "target": "ES2017"
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
